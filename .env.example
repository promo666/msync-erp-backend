# Copy this file to .env and fill in real values before running in production

# Long random secret used to sign login tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string

# Port the API server listens on
PORT=4000

# Comma-separated list of frontend origins allowed to call this API
# e.g. https://your-app.pages.dev,https://msync.yourcompany.com
CORS_ORIGIN=http://localhost:5173

# Path to the SQLite database file (make sure this is on a PERSISTENT volume
# if you deploy to Railway/Render/etc, otherwise data is lost on redeploy)
DB_PATH=./data/msync.db

# Initial owner account created on first run (change the password immediately after first login)
SEED_OWNER_EMAIL=owner@yourcompany.com
SEED_OWNER_PASSWORD=ChangeMe123!
SEED_OWNER_NAME=Owner
